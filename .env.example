# Privy credentials (Dashboard → Settings → Basics)
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Anthropic API (direct or proxy)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: proxy support (overrides ANTHROPIC_API_KEY)
# ANTHROPIC_BASE_URL=https://cc.ai.cmsd.dev/api
# ANTHROPIC_AUTH_TOKEN=cr_...

# Login 3.0 OIDC (for Custom Auth integration)
NEXT_PUBLIC_LOGIN3_DOMAIN=https://auth3.upbond.io
NEXT_PUBLIC_LOGIN3_CLIENT_ID=your-login3-client-id
NEXT_PUBLIC_LOGIN3_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_LOGIN3_SCOPES=openid profile email wallet
LOGIN3_CLIENT_SECRET=your-login3-client-secret
